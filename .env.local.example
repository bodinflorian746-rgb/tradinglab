# ════════════════════════════════════════════════════════════════════════
#   .env.local.example
#
#   Copie ce fichier en .env.local et remplis les valeurs (jamais commit).
#   À chaque ajout de variable ici, redémarrer `npm run dev` après update.
# ════════════════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ton-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# ⚠️ secret, bypass RLS. Ne JAMAIS exposer côté client ni commit.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ─── Journal IA — Mode démo local (DEV UNIQUEMENT) ────────────────────────
# Mettre à "true" pour valider l'UX du Journal sans Supabase : 5 trades
# fictifs, succès simulé à l'ajout, aucun insert ni upload réel. Un badge
# "Mode démo local" s'affiche sur /journal.
# ⚠️ Ignoré en production (NODE_ENV=production) quoi qu'il arrive. Laisser
# vide ou retirer cette ligne avant de tester la vraie connexion Supabase.
NEXT_PUBLIC_JOURNAL_MOCK_MODE=false

# ─── App ──────────────────────────────────────────────────────────────────
# URL publique de l'app (utilisée pour les success_url / cancel_url Stripe,
# emails de confirmation Supabase, etc.). En dev : http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email autorisé à accéder à la page admin /[locale]/admin/codes (génération
# et liste des codes d'accès). Toute autre session reçoit un 404.
ADMIN_EMAIL=ton.email@example.com

# ─── Resend ─────────────────────────────────────────────────────────────────
# Clé API Resend pour l'envoi du code d'activation au signup (server-only).
# From : noreply@tradescalex.com (domaine à vérifier côté Resend).
# À ajouter AUSSI dans les Environment Variables Vercel.
RESEND_API_KEY=re_xxx

# ─── Stripe ───────────────────────────────────────────────────────────────
# Mode actif : "test" ou "live".
#   - test : sandbox Stripe, aucun débit réel, cartes test 4242…
#   - live : production, débits RÉELS
#
# Pour switcher :
#   1. Changer STRIPE_MODE ci-dessous
#   2. S'assurer que le bloc correspondant (TEST ou LIVE) est rempli
#   3. Redémarrer `npm run dev` (Next ne relit .env.local qu'au boot)
#
# Si STRIPE_MODE est absent, le code fallback automatiquement à "test"
# (mode safe par défaut, évite tout débit accidentel).
STRIPE_MODE=test

# ----- TEST (Stripe Dashboard mode "Test", aucun paiement réel) -----
# Dashboard → Developers → API keys (en mode Test)
# Webhook secret : viens de `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_TEST_WEBHOOK_SECRET=whsec_xxx
STRIPE_TEST_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_xxx

# ----- LIVE (Stripe Dashboard mode "Live", paiements RÉELS) -----
# ⚠️ Ne JAMAIS utiliser ces clés en dev sauf test d'intégration explicite.
# Dashboard → Developers → API keys (en mode Live)
# Webhook secret : depuis le webhook endpoint enregistré dans le Dashboard.
STRIPE_LIVE_SECRET_KEY=sk_live_xxx
STRIPE_LIVE_WEBHOOK_SECRET=whsec_xxx
STRIPE_LIVE_PRICE_ID=price_xxx
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_xxx
